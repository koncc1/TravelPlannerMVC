@model List<TravelPlannerMVC.Models.TravelRequest>

@{
    ViewData["Title"] = "Travel Requests";
}

<h2 class="mb-4">Travel Requests Management</h2>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No travel requests yet.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Start City</th>
                <th>End City</th>
                <th>Preferred Date</th>
                <th>Status</th>
                <th>Change Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.StartCity</td>
                    <td>@request.EndCity</td>
                    <td>@request.PreferredDate.ToString("dd.MM.yyyy")</td>
                    <td>@request.Status</td>
                    <td>
                        <form asp-controller="TravelRequests" asp-action="ChangeStatus" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@request.Id" />
                            <input type="hidden" name="status" value="Approved" />

                            <button type="submit" class="btn btn-sm btn-success">
                                Approve
                            </button>
                        </form>

                        <form asp-controller="TravelRequests" asp-action="ChangeStatus" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@request.Id" />
                            <input type="hidden" name="status" value="Rejected" />

                            <button type="submit" class="btn btn-sm btn-danger">
                                Reject
                            </button>
                        </form>

                        <form asp-controller="TravelRequests" asp-action="ChangeStatus" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@request.Id" />
                            <input type="hidden" name="status" value="Completed" />

                            <button type="submit" class="btn btn-sm btn-secondary">
                                Complete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}