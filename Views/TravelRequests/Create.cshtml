@model TravelPlannerMVC.ViewModels.TravelRequestCreateViewModel

@{
    ViewData["Title"] = "Create Travel Request";
}

<h2 class="mb-4">Create Travel Request</h2>

<form asp-controller="TravelRequests" asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="StartCity" class="form-label"></label>
        <input asp-for="StartCity" class="form-control" />
        <span asp-validation-for="StartCity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndCity" class="form-label"></label>
        <input asp-for="EndCity" class="form-control" />
        <span asp-validation-for="EndCity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PreferredDate" class="form-label"></label>
        <input asp-for="PreferredDate" type="date" class="form-control" />
        <span asp-validation-for="PreferredDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-dark">
        Send Request
    </button>

    <a asp-controller="TravelRequests" asp-action="MyRequests" class="btn btn-secondary">
        Back
    </a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}