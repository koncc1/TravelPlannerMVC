@model List<TravelPlannerMVC.Models.TravelRequest>

@{
    ViewData["Title"] = "My Requests";
}

<h2 class="mb-4">My Travel Requests</h2>

<a asp-controller="TravelRequests" asp-action="Create" class="btn btn-dark mb-3">
    Create Request
</a>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        You do not have any travel requests yet.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Start City</th>
                <th>End City</th>
                <th>Preferred Date</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.StartCity</td>
                    <td>@request.EndCity</td>
                    <td>@request.PreferredDate.ToString("dd.MM.yyyy")</td>
                    <td>@request.Status</td>
                </tr>
            }
        </tbody>
    </table>
}