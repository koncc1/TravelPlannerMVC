@model List<TravelPlannerMVC.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<h2 class="mb-4">My Bookings</h2>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        You do not have any bookings yet.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Route</th>
                <th>Departure</th>
                <th>Seats</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>
                        @booking.TravelRoute?.StartCity → @booking.TravelRoute?.EndCity
                    </td>

                    <td>
                        @booking.TravelRoute?.DepartureDate.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td>
                        @booking.SeatsCount
                    </td>

                    <td>
                        @booking.Status
                    </td>

                    <td>
                        @if (booking.Status != "Cancelled")
                        {
                            <form asp-controller="Bookings" asp-action="Cancel" asp-route-id="@booking.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Cancel
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">Cancelled</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}