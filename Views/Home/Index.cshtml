@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section text-center text-light rounded-4 p-5 mb-4">
    <h1 class="display-4 fw-bold">Travel Planner</h1>
    <p class="lead mt-3">
        Manage routes, bookings and travel requests in one simple system.
    </p>

    <div class="mt-4">
        <a class="btn btn-light btn-lg me-2" asp-controller="TravelRoutes" asp-action="Index">
            Explore Routes
        </a>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a class="btn btn-outline-light btn-lg" asp-controller="Bookings" asp-action="MyBookings">
                My Bookings
            </a>
        }
    </div>
</div>

<div class="row g-4 mt-3">

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h5 class="card-title">🚀 Fast Booking</h5>
                <p class="card-text">
                    Book travel routes in seconds with automatic seat management.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h5 class="card-title">📍 Smart Routes</h5>
                <p class="card-text">
                    Browse available travel routes with real-time availability.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body">
                <h5 class="card-title">🔐 Secure System</h5>
                <p class="card-text">
                    Role-based access control and protected user data.
                </p>
            </div>
        </div>
    </div>

</div>