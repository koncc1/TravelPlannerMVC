@model TravelPlannerMVC.Models.TravelRoute

@{
    ViewData["Title"] = "Route Details";
}

<h2 class="mb-4">Route Details</h2>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">
            @Model.StartCity → @Model.EndCity
        </h5>

        <p>
            <strong>Departure:</strong>
            @Model.DepartureDate.ToString("dd.MM.yyyy HH:mm")
        </p>

        <p>
            <strong>Price:</strong>
            @Model.Price Kč
        </p>

        <p>
            <strong>Available seats:</strong>
            @Model.AvailableSeats
        </p>

        <a asp-controller="TravelRoutes" asp-action="Index" class="btn btn-secondary">
            Back
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-controller="TravelRoutes" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit
            </a>
        }


        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a asp-controller="Bookings" asp-action="Create" asp-route-routeId="@Model.Id" class="btn btn-success">
                Book this route
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-success">
                Login to book
            </a>
        }
    </div>
</div>