@model TravelPlannerMVC.Models.TravelRoute

@{
    ViewData["Title"] = "Delete Route";
}

<h2 class="mb-4">Delete Route</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this route?
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">
            @Model.StartCity → @Model.EndCity
        </h5>

        <p>
            <strong>Departure:</strong>
            @Model.DepartureDate.ToString("dd.MM.yyyy HH:mm")
        </p>

        <p>
            <strong>Price:</strong>
            @Model.Price Kč
        </p>

        <p>
            <strong>Available seats:</strong>
            @Model.AvailableSeats
        </p>
    </div>
</div>

<form asp-controller="TravelRoutes" asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-controller="TravelRoutes" asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>