@model TravelPlannerMVC.Areas.Admin.Models.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .admin-dashboard {
        padding: 20px;
    }

    .admin-header {
        background: #fff;
        padding: 16px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 1px solid #e9ecef;
    }

    .admin-title {
        font-size: 20px;
        font-weight: 600;
        margin: 0;
    }

    .admin-subtitle {
        font-size: 13px;
        color: #6c757d;
        margin-top: 2px;
    }

    .stat-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 15px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        transition: 0.2s ease;
    }

    .stat-card:hover {
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    .stat-value {
        font-size: 24px;
        font-weight: 700;
        margin: 0;
        color: #212529;
    }

    .stat-label {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .icon {
        font-size: 28px;
        opacity: 0.3;
        float: right;
    }

    .blue { color: #0d6efd; }
    .green { color: #198754; }
    .orange { color: #fd7e14; }
    .purple { color: #6f42c1; }
</style>

<div class="admin-dashboard">

    <!-- HEADER -->
    <div class="admin-header">
        <h2 class="admin-title">Admin Dashboard</h2>
        <div class="admin-subtitle">Basic platform statistics</div>
    </div>

    <!-- ROWS (Bootstrap only) -->
    <div class="row">

        <div class="col-md-3">
            <div class="stat-card">
                <i class="bi bi-people-fill icon blue"></i>
                <div class="stat-label">Users</div>
                <div class="stat-value">@Model.UsersCount</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <i class="bi bi-compass-fill icon green"></i>
                <div class="stat-label">Routes</div>
                <div class="stat-value">@Model.RoutesCount</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <i class="bi bi-calendar-check-fill icon purple"></i>
                <div class="stat-label">Bookings</div>
                <div class="stat-value">@Model.BookingsCount</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <i class="bi bi-clipboard-data-fill icon orange"></i>
                <div class="stat-label">Requests</div>
                <div class="stat-value">@Model.RequestsCount</div>
            </div>
        </div>

    </div>

</div>